generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

model ProductCategory {
  id           String    @id @default(cuid())
  slug         String    @unique
  name         String
  description  String
  image        String    @default("")
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  products     Product[]
}

enum ProductUnit {
  MTR
  PCS
  FEET
  KG
}

model Product {
  id             String          @id @default(cuid())
  slug           String          @unique
  name           String
  sku            String          @unique
  hsn            String          @default("")
  unit           ProductUnit     @default(PCS)
  stock          Int             @default(0)
  description    String
  price          Float           @default(0)
  specifications String          @default("{}") // JSON string
  applications   String          @default("[]") // JSON string
  image          String          @default("")
  isNewArrival   Boolean         @default(false)
  isFeatured     Boolean         @default(false)
  isActive       Boolean         @default(true)
  categoryId     String
  category       ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  inquiries      Inquiry[]
}

model Customer {
  id            String   @id @default(cuid())
  name          String
  contactPerson String
  phone         String
  email         String   @unique
  gstin         String   @default("")
  address       String   @default("")
  city          String   @default("")
  state         String   @default("")
  pincode       String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Inquiry {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String
  company     String   @default("")
  message     String
  quantity    String   @default("")
  productId   String?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName String   @default("")
  source      String   @default("website") // website, whatsapp
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Invoice {
  id                  String         @id @default(cuid())
  documentType        String         @default("invoice")
  billType            String         @default("Invoice")
  invoiceNumber       String         @unique
  invoiceDate         DateTime
  dueDate             DateTime?
  partyName           String
  contactPerson       String         @default("")
  email               String         @default("")
  remindersPaused     Boolean        @default(false)
  phone               String         @default("")
  city                String         @default("")
  pincode             String         @default("")
  gstin               String         @default("")
  state               String         @default("")
  address             String         @default("")
  poDate              DateTime?
  ewayBillNo          String         @default("")
  poNo                String         @default("")
  placeOfSupply       String         @default("")
  shipToAddress       String         @default("")
  transportName       String         @default("")
  vehicleNumber       String         @default("")
  taxType             String         @default("cgst-sgst")
  paymentMode         String         @default("")
  notes               String         @default("")
  terms               String         @default("")
  bankDetails         String         @default("")
  authorizedSignature String         @default("")
  subtotal            Float          @default(0)
  discountTotal       Float          @default(0)
  extraDiscountAmount Float          @default(0)
  taxableAmount       Float          @default(0)
  taxAmount            Float          @default(0)
  roundOff            Float          @default(0)
  grandTotal          Float          @default(0)
  convertedToTaxInvoice Boolean       @default(false)
  convertedInvoiceId  String?
  convertedInvoiceNumber String?
  convertedFromProforma Boolean       @default(false)
  sourceProformaNumber String?
  items               InvoiceItem[]
  reminders           InvoiceReminder[]
  payments            Payment[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

model InvoiceItem {
  id                  String   @id @default(cuid())
  invoiceId           String
  invoice             Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description         String
  hsn                 String   @default("")
  unit                String   @default("")
  qty                 Int      @default(0)
  rate                Float    @default(0)
  taxPercent          Float    @default(0)
  discountPercent     Float    @default(0)
  taxablePerUnit      Float    @default(0)
  taxableAmount       Float    @default(0)
  gstAmount           Float    @default(0)
  finalRatePerUnit    Float    @default(0)
  rowAmount           Float    @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model ProformaInvoice {
  id                  String                @id @default(cuid())
  documentType        String                @default("proforma")
  billType            String                @default("Proforma Invoice")
  invoiceNumber       String                @unique
  convertedToTaxInvoice Boolean              @default(false)
  convertedInvoiceId  String?
  convertedInvoiceNumber String?
  convertedFromProforma Boolean              @default(false)
  sourceProformaNumber String?
  invoiceDate         DateTime
  dueDate             DateTime?
  partyName           String
  contactPerson       String                @default("")
  email               String                @default("")
  phone               String                @default("")
  city                String                @default("")
  pincode             String                @default("")
  gstin               String                @default("")
  state               String                @default("")
  address             String                @default("")
  poDate              DateTime?
  ewayBillNo          String                @default("")
  poNo                String                @default("")
  placeOfSupply       String                @default("")
  shipToAddress       String                @default("")
  transportName       String                @default("")
  vehicleNumber       String                @default("")
  taxType             String                @default("cgst-sgst")
  paymentMode         String                @default("")
  notes               String                @default("")
  terms               String                @default("")
  bankDetails         String                @default("")
  authorizedSignature String                @default("")
  subtotal            Float                 @default(0)
  discountTotal       Float                 @default(0)
  extraDiscountAmount Float                 @default(0)
  taxableAmount       Float                 @default(0)
  taxAmount           Float                 @default(0)
  roundOff            Float                 @default(0)
  grandTotal          Float                 @default(0)
  items               ProformaInvoiceItem[]
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
}

model Quotation {
  id                     String          @id @default(cuid())
  documentType           String          @default("quotation")
  billType               String          @default("Quotation")
  invoiceNumber          String          @unique
  convertedToTaxInvoice  Boolean         @default(false)
  convertedInvoiceId     String?
  convertedInvoiceNumber String?
  convertedFromProforma  Boolean         @default(false)
  sourceProformaNumber   String?
  invoiceDate            DateTime
  dueDate                DateTime?
  partyName              String
  contactPerson          String          @default("")
  email                  String          @default("")
  phone                  String          @default("")
  city                   String          @default("")
  pincode                String          @default("")
  gstin                  String          @default("")
  state                  String          @default("")
  address                String          @default("")
  poDate                 DateTime?
  ewayBillNo             String          @default("")
  poNo                   String          @default("")
  placeOfSupply          String          @default("")
  shipToAddress          String          @default("")
  transportName          String          @default("")
  vehicleNumber          String          @default("")
  taxType                String          @default("cgst-sgst")
  paymentMode            String          @default("")
  notes                  String          @default("")
  terms                  String          @default("")
  bankDetails            String          @default("")
  authorizedSignature    String          @default("")
  subtotal               Float           @default(0)
  discountTotal          Float           @default(0)
  extraDiscountAmount    Float           @default(0)
  taxableAmount          Float           @default(0)
  taxAmount              Float           @default(0)
  roundOff               Float           @default(0)
  grandTotal             Float           @default(0)
  items                  QuotationItem[]
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
}

model QuotationItem {
  id               String    @id @default(cuid())
  quotationId      String
  quotation        Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  description      String
  hsn              String    @default("")
  unit             String    @default("")
  qty              Int       @default(0)
  rate             Float     @default(0)
  taxPercent       Float     @default(0)
  discountPercent  Float     @default(0)
  taxablePerUnit   Float     @default(0)
  taxableAmount    Float     @default(0)
  gstAmount        Float     @default(0)
  finalRatePerUnit Float     @default(0)
  rowAmount        Float     @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model ProformaInvoiceItem {
  id                  String            @id @default(cuid())
  proformaInvoiceId   String
  proformaInvoice     ProformaInvoice   @relation(fields: [proformaInvoiceId], references: [id], onDelete: Cascade)
  description         String
  hsn                 String            @default("")
  unit                String            @default("")
  qty                 Int               @default(0)
  rate                Float             @default(0)
  taxPercent          Float             @default(0)
  discountPercent     Float             @default(0)
  taxablePerUnit      Float             @default(0)
  taxableAmount       Float             @default(0)
  gstAmount           Float             @default(0)
  finalRatePerUnit    Float             @default(0)
  rowAmount           Float             @default(0)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model Annexure {
  id                  String         @id @default(cuid())
  documentType        String         @default("annexure")
  billType            String         @default("Annexure")
  invoiceNumber       String         @unique
  invoiceDate         DateTime
  dueDate             DateTime?
  partyName           String
  contactPerson       String         @default("")
  email               String         @default("")
  phone               String         @default("")
  city                String         @default("")
  pincode             String         @default("")
  gstin               String         @default("")
  state               String         @default("")
  address             String         @default("")
  poDate              DateTime?
  ewayBillNo          String         @default("")
  poNo                String         @default("")
  placeOfSupply       String         @default("")
  shipToAddress       String         @default("")
  transportName       String         @default("")
  vehicleNumber       String         @default("")
  taxType             String         @default("cgst-sgst")
  paymentMode         String         @default("")
  notes               String         @default("")
  terms               String         @default("")
  bankDetails         String         @default("")
  authorizedSignature String         @default("")
  subtotal            Float          @default(0)
  discountTotal       Float          @default(0)
  extraDiscountAmount Float          @default(0)
  taxableAmount       Float          @default(0)
  taxAmount           Float          @default(0)
  grandTotal          Float          @default(0)
  items               AnnexureItem[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

model AnnexureItem {
  id              String   @id @default(cuid())
  annexureId      String
  annexure        Annexure @relation(fields: [annexureId], references: [id], onDelete: Cascade)
  description     String
  hsn             String   @default("")
  unit            String   @default("")
  qty             Int      @default(0)
  rate            Float    @default(0)
  taxPercent      Float    @default(0)
  discountPercent Float    @default(0)
  taxablePerUnit  Float    @default(0)
  taxableAmount   Float    @default(0)
  gstAmount       Float    @default(0)
  finalRatePerUnit Float    @default(0)
  rowAmount       Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ServiceSpecialization {
  id               String   @id @default(cuid())
  title            String
  shortDescription String
  fullDescription  String
  image            String   @default("")
  sortOrder        Int      @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model InvoiceReminder {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  type      String
  sentAt    DateTime @default(now())
  meta      String?  @default("")
  createdAt DateTime @default(now())

  @@unique([invoiceId, type])
}

model Payment {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount      Float
  paymentMode String   @default("Cash")
  note        String   @default("")
  paidAt      DateTime @default(now())
  createdAt   DateTime @default(now())
}
